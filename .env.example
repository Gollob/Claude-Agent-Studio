# claude-agent-studio — environment variables
# Copy to .env (chmod 600) and fill in your values.
# DO NOT commit .env to git.

# ── Telegram bot ──────────────────────────────────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_TOKEN=

# Your personal Telegram chat ID (use @userinfobot to find it)
TELEGRAM_CHAT_ID=

# ── Anthropic API ─────────────────────────────────────────────────────────────
# Claude API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Alternative: Claude OAuth token (for claude CLI authenticated session)
# CLAUDE_CODE_OAUTH_TOKEN=

# ── Agent workdir ─────────────────────────────────────────────────────────────
# Root directory where agent mode subdirectories live (e.g. ~/agents/dev)
AGENT_WORKDIR=~/agents

# ── Bot IPC directory ─────────────────────────────────────────────────────────
AGENT_IPC_DIR=/tmp/agent-studio

# ── file-intake service ───────────────────────────────────────────────────────
# Auth token for /process HTTP endpoint (leave empty to disable auth)
AUTH_TOKEN=

# Max file size in MB
MAX_FILE_MB=50

# Telegram bot token for file-intake (can reuse TELEGRAM_TOKEN)
# TELEGRAM_TOKEN is already set above — file-intake reads it from env

# Comma-separated list of allowed Telegram user IDs for file-intake bot
TG_ALLOWED_USER_IDS=

# ── Trilium ETAPI (optional) ──────────────────────────────────────────────────
# Leave empty to use stdout/file sink instead
TRILIUM_ETAPI=
TRILIUM_TOKEN=
TRILIUM_TOKEN_FILE=
# JSON mapping of section names to Trilium noteIds
# e.g. TRILIUM_NOTE_IDS={"default": "YOUR_NOTE_ID", "analyses": "ANOTHER_ID"}
TRILIUM_NOTE_IDS=
TRILIUM_DEFAULT_NOTE_ID=root

# ── task-router ───────────────────────────────────────────────────────────────
TR_PORT=8092
TR_CATALOG_PATH=./tagcatalog/tags.yaml
TR_SCHEMA_PATH=./tagcatalog/tags.schema.json
TR_DB_DSN=file:./data/task-router.db?cache=shared&_journal=WAL

# ── OpenTelemetry (optional) ──────────────────────────────────────────────────
# Leave OTEL_EXPORTER_OTLP_ENDPOINT empty to disable tracing
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAMESPACE=agent-studio
OTEL_DEPLOYMENT_ENV=production
UPTRACE_PROJECT_TOKEN=

# ── Whisper STT ───────────────────────────────────────────────────────────────
WHISPER_MODEL=small
WHISPER_COMPUTE=int8
WHISPER_LANGUAGE=en

# ── Trilium board (optional, for board.sh.example) ───────────────────────────
TRILIUM_ETAPI_BASE=http://localhost:8080/etapi
TRILIUM_ETAPI_TOKEN_FILE=~/.config/trilium-etapi-token
DEV_ROOT_NOTE_ID=
TRILIUM_HOST_URL=http://localhost:8080
